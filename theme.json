{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "color": {
      "custom": true,
      "defaultPalette": true,
      "palette": [
        {
          "color": "#111827",
          "name": "Text",
          "slug": "text"
        },
        {
          "color": "#ffffff",
          "name": "Background",
          "slug": "background"
        },
        {
          "color": "#f3f4f6",
          "name": "Surface",
          "slug": "surface"
        },
        {
          "color": "#2563eb",
          "name": "Accent",
          "slug": "accent"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "margin": true,
      "padding": true,
      "units": [
        "px",
        "rem",
        "%"
      ]
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "1rem",
          "slug": "base"
        },
        {
          "fluid": {
            "max": "1.375rem",
            "min": "1.125rem"
          },
          "name": "Large",
          "size": "1.25rem",
          "slug": "large"
        },
        {
          "fluid": {
            "max": "3rem",
            "min": "2rem"
          },
          "name": "Display",
          "size": "2.75rem",
          "slug": "display"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        }
      }
    }
  }
}
